  "components": {
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "nullable": true
          },
          "user": {
            "$ref": "#/components/schemas/UserDetails"
          }
        },
        "additionalProperties": false
      },
      "JobMatchRequest": {
        "type": "object",
        "properties": {
          "resumeId": {
            "type": "string",
            "format": "uuid"
          },
          "topN": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "JobMatchResult": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "company": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "requiredSkills": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "matchedSkills": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "missingSkills": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MissingSkillDetail"
            },
            "nullable": true
          },
          "matchScore": {
            "type": "number",
            "format": "double"
          },
          "matchExplanation": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "MissingSkillDetail": {
        "type": "object",
        "properties": {
          "skillName": {
            "type": "string",
            "nullable": true
          },
          "explanation": {
            "type": "string",
            "nullable": true
          },
          "jobRelevance": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ResourceLink": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "nullable": true
          },
          "url": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ResourceResult": {
        "type": "object",
        "properties": {
          "skill": {
            "type": "string",
            "nullable": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          },
          "youTubeLinks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ResourceLink"
            },
            "nullable": true
          },
          "articleLinks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ResourceLink"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ResumeUploadResponse": {
        "type": "object",
        "properties": {
          "resumeId": {
            "type": "string",
            "format": "uuid"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "fileName": {
            "type": "string",
            "nullable": true
          },
          "extractedSkills": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SkillGapResult": {
        "type": "object",
        "properties": {
          "resumeId": {
            "type": "string",
            "format": "uuid"
          },
          "jobId": {
            "type": "integer",
            "format": "int32"
          },
          "jobTitle": {
            "type": "string",
            "nullable": true
          },
          "company": {
            "type": "string",
            "nullable": true
          },
          "resumeSkills": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "matchedSkills": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "missingSkills": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MissingSkillDetail"
            },
            "nullable": true
          },
          "matchScore": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "UserDetails": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "JWT Authorization header using the Bearer scheme. Example: \"Authorization: Bearer {token}\"",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}